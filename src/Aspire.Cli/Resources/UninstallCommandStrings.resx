  <data name="Description" xml:space="preserve">
    <value>Uninstall an Aspire CLI installation</value>
  </data>
  <data name="PrOptionDescription" xml:space="preserve">
    <value>Uninstall the PR / dogfood install at the default location (~/.aspire/dogfood/pr-&lt;N&gt;)</value>
  </data>
  <data name="PrefixArgumentDescription" xml:space="preserve">
    <value>Absolute path of the install prefix to uninstall</value>
  </data>
  <data name="YesOptionDescription" xml:space="preserve">
    <value>Skip the confirmation prompt and proceed with removal</value>
  </data>
  <data name="DryRunOptionDescription" xml:space="preserve">
    <value>Print the actions that would be performed without modifying anything</value>
  </data>
  <data name="MissingTargetError" xml:space="preserve">
    <value>Specify what to uninstall: either --pr &lt;N&gt; or an explicit install prefix path.</value>
  </data>
  <data name="ConflictingTargetsError" xml:space="preserve">
    <value>--pr and an explicit prefix path are mutually exclusive. Specify only one.</value>
  </data>
  <data name="PrefixHeader" xml:space="preserve">
    <value>Install prefix: {0}</value>
    <comment>{0} is the absolute path of the install prefix being uninstalled.</comment>
  </data>
  <data name="RouteHeader" xml:space="preserve">
    <value>Detected route: {0}</value>
    <comment>{0} is the install route wire string (script / pr / winget / brew / dotnet-tool).</comment>
